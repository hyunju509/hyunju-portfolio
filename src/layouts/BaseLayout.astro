---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<title>{title}</title>
<link href="https://fonts.googleapis.com" rel="preconnect" />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,900&family=Archivo:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body id="top-anchor">
<slot />
<script defer src="/js/site.js"></script>
</body>
</html>
