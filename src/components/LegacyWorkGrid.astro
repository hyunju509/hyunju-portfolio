---
interface Project {
  id: string;
  title: string;
  image: string;
  tags?: string;
  hasRoom: boolean;
}

const projects: Project[] = [
  { id: "calibrated", title: "Calibrated Environment", image: "/images/portfolio-pages/calibrated-environment/02-calibrated-01.jpg", tags: "nyc,tower", hasRoom: true },
  { id: "fluid", title: "Fluid Terrain", image: "/images/portfolio-pages/fluid-terrain/01-fluid-01.jpg", tags: "landscape", hasRoom: true },
  { id: "surreal", title: "Surreal Museum Tower", image: "/images/portfolio-pages/surreal-museum-tower/03-surreal-01.jpg", tags: "nyc,museum", hasRoom: true },
  { id: "shadow", title: "Shadow Archive", image: "/images/portfolio-pages/shadow-archive/04-shadow-01.jpg", tags: "research", hasRoom: true },
  { id: "spectrum", title: "Spectrum Living", image: "/images/portfolio-pages/spectrum-living/07-spectrum-01.jpg", tags: "housing", hasRoom: true },
  { id: "ordinary", title: "Ordinary Village", image: "/images/portfolio-pages/ordinary-village/05-ordinary-01.jpg", hasRoom: false },
  { id: "ivanpah", title: "Ivanpah Solar Sanctuary", image: "/images/portfolio-pages/ivanpah-solar-sanctuary/06-ivanpah-01.jpg", hasRoom: false },
];
---
<main class="work" id="work">
<div class="selected-grid" id="grid">
{projects.map((p) => (
  p.hasRoom ? (
    <figure aria-label={`Open ${p.title}`} class="proj-card item" data-id={p.id} data-tags={p.tags} role="button" tabindex="0">
      <div class="thumb"><img alt={p.title} loading="lazy" src={p.image} /></div>
      <figcaption><span class="ct">{p.title}</span></figcaption>
    </figure>
  ) : (
    <figure class="proj-card">
      <div class="thumb"><img alt={p.title} loading="lazy" src={p.image} /></div>
      <figcaption><span class="ct">{p.title}</span></figcaption>
    </figure>
  )
))}
</div>
</main>
