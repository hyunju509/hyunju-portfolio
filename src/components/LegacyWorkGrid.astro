---
import { PROJECTS } from '../data/projects';
import GridItem from './GridItem.astro';

const tierA = PROJECTS.filter((p) => p.tier === 'A');
const tierB = PROJECTS.filter((p) => p.tier === 'B');
---
<main class="work" id="work">
<div class="selected-grid" id="grid">
{tierA.map((p, i) => <GridItem p={p} i={i} />)}
{tierB.length > 0 && (
  <div class="more-work-heading" role="presentation">
    <span>More Work</span>
  </div>
)}
{tierB.map((p, i) => <GridItem p={p} i={tierA.length + i} />)}
</div>
<div aria-hidden="true" class="gx-ghost" id="gx-ghost"><img alt="" /></div>
</main>

<script>
  import '../scripts/project-expand';
</script>
