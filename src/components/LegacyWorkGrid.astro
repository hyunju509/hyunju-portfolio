---
import { PROJECTS, pad, cardImage, cardSecondary } from '../data/projects';
---
<main class="work" id="work">
<div class="selected-grid" id="grid">
{PROJECTS.map((p, i) => (
  <figure aria-label={`Open ${p.title} project`} class="proj-card" data-id={p.id} role="button" tabindex="0">
    <div class="thumb">
      <img class="p1" alt={p.title} loading="lazy" src={cardImage(p)} />
      {cardSecondary(p) && <img class="p2" alt="" aria-hidden="true" loading="lazy" src={cardSecondary(p)} />}
    </div>
    <figcaption>
      <span class="pnum">{pad(i + 1)}</span>
      <span class="ct">{p.title}</span>
      <span class="pmeta">{p.cardMeta}</span>
    </figcaption>
  </figure>
))}
</div>
</main>
