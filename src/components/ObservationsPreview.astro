---
import { getFeaturedPreviews } from '../lib/sanity/content';

/* Sanity-controlled selections (Site Settings → Homepage Observations
   preview): exactly 8 + 8, validated at build time. */
const { places, studies, intro, placesLabel, imageStudiesLabel } = await getFeaturedPreviews();
---
<section class="home-obs" id="home-observations">
  <div class="home-obs-head">
    <h2>Observations</h2>
    <p>{intro}</p>
  </div>

  <div class="home-obs-group">
    <div class="home-obs-group-head">
      <h3>{placesLabel}</h3>
      <a href="/observations#places">View {placesLabel} <span aria-hidden="true">&rarr;</span></a>
    </div>
    <div class="home-obs-grid">
      {places.map((p) => (
        <a class="home-obs-tile" href="/observations#places" aria-label={`View ${p.title} photographs in Observations`}>
          <img src={p.thumb} alt="" width="600" height="600" loading="lazy" decoding="async" />
          <span class="home-obs-tile-label" aria-hidden="true">{p.title}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="home-obs-group">
    <div class="home-obs-group-head">
      <h3>{imageStudiesLabel}</h3>
      <a href="/observations#image-studies">View {imageStudiesLabel} <span aria-hidden="true">&rarr;</span></a>
    </div>
    <div class="home-obs-grid">
      {studies.map((s) => (
        <a class="home-obs-tile" href="/observations#image-studies" aria-label={`View ${s.title} in Observations`}>
          <img src={s.thumb} alt="" width="600" height="600" loading="lazy" decoding="async" />
          <span class="home-obs-tile-label" aria-hidden="true">{s.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.home-obs {
  padding: 32px 5vw 2vh;
  border-top: 1px solid var(--hair);
}

/* Match the narrowed homepage content width (.work) on desktop/laptop. */
@media (min-width: 1025px) {
  .home-obs {
    padding-left: 8.6vw;
    padding-right: 8.6vw;
  }
}

.home-obs-head {
  margin-bottom: 20px;
}

.home-obs-head h2 {
  font-family: 'Archivo', sans-serif;
  font-weight: 400;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gray2);
  margin-bottom: 4px;
}

.home-obs-head p {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 12px;
  line-height: 1.5;
  color: var(--gray2);
  max-width: 720px;
}

.home-obs-group {
  margin-bottom: 20px;
}

.home-obs-group:last-child {
  margin-bottom: 0;
}

.home-obs-group-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8px;
}

.home-obs-group-head h3 {
  font-family: 'Archivo', sans-serif;
  font-weight: 400;
  font-size: 13px;
  letter-spacing: 0.02em;
  color: var(--ink);
}

.home-obs-group-head a {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 11px;
  letter-spacing: 0.02em;
  color: var(--gray2);
  text-decoration: none;
  transition: color 0.2s ease-out;
}

.home-obs-group-head a:hover {
  color: var(--ink);
}

.home-obs-group-head a:focus-visible {
  outline: 2px solid var(--ink);
  outline-offset: 3px;
}

.home-obs-grid {
  display: grid;
  grid-template-columns: repeat(8, minmax(0, 1fr));
  gap: 10px;
}

@media (max-width: 1280px) {
  .home-obs-grid { grid-template-columns: repeat(6, minmax(0, 1fr)); }
}
@media (max-width: 1024px) {
  .home-obs-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
}
@media (max-width: 640px) {
  .home-obs-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
}
@media (max-width: 359px) {
  .home-obs-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}

.home-obs-tile {
  position: relative;
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f2f2ee;
}

.home-obs-tile img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.2s ease-out;
}

.home-obs-tile:hover img,
.home-obs-tile:focus-visible img {
  opacity: 0.85;
}

.home-obs-tile:focus-visible {
  outline: 2px solid var(--ink);
  outline-offset: -2px;
}

.home-obs-tile-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 3px 4px;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 8.5px;
  letter-spacing: 0.02em;
  color: #fff;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
  opacity: 0;
  transform: translateY(3px);
  transition: opacity 0.2s ease-out, transform 0.2s ease-out;
  pointer-events: none;
}

.home-obs-tile:hover .home-obs-tile-label,
.home-obs-tile:focus-visible .home-obs-tile-label {
  opacity: 1;
  transform: translateY(0);
}

@media (prefers-reduced-motion: reduce) {
  .home-obs-tile img,
  .home-obs-tile-label,
  .home-obs-group-head a {
    transition: none;
  }
}
</style>
