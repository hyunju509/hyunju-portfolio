---
import { pad, cardImage, cardSecondary, sheetPath, sheetDims, type Project } from '../data/projects';

interface Props {
  p: Project;
  i: number;
}
const { p, i } = Astro.props;
---
<article class="gitem" data-id={p.id} data-index={i} data-tier={p.tier}>
  <figure aria-expanded="false" aria-label={`Expand ${p.title} project`} class="proj-card" data-id={p.id} role="button" tabindex="0">
    <div class="thumb">
      <img class="p1" alt={p.title} loading="lazy" src={cardImage(p)} />
      {cardSecondary(p) && <img class="p2" alt="" aria-hidden="true" loading="lazy" src={cardSecondary(p)} />}
    </div>
    <figcaption>
      <span class="pnum">{pad(i + 1)}</span>
      <span class="ct">{p.title}</span>
      <span class="pmeta">{p.cardMeta}</span>
    </figcaption>
  </figure>
  <div class="gx" hidden tabindex="-1" aria-label={`${p.title} — expanded project`}>
    <aside class="gx-rail">
      <span class="gx-num">{pad(i + 1)}</span>
      <h2 class="gx-title">{p.title}</h2>
      <p class="gx-mmeta">{p.cardMeta}</p>
      <dl class="gx-meta">
      {p.meta.map((row) => (
        <div><dt>{row.k}</dt><dd>{row.v}</dd></div>
      ))}
      </dl>
      <button class="gx-close" aria-label={`Close ${p.title}`}>&larr; Close</button>
    </aside>
    <div class="gx-field">
      <div class="gx-media">
        <div class="gx-track">
        {p.sheets.map((sheet, j) => {
          const dims = sheetDims(sheet);
          return (
            <figure class="gx-page">
              <img
                alt={`${p.title} — sheet ${j + 1} of ${p.sheets.length}`}
                decoding="async"
                height={dims.height}
                loading="lazy"
                src={sheetPath(p, sheet)}
                width={dims.width}
              />
            </figure>
          );
        })}
        </div>
        <button aria-label={`Previous ${p.title} page`} class="gx-zone gx-prev"></button>
        <button aria-label={`Next ${p.title} page`} class="gx-zone gx-next"></button>
      </div>
      <p aria-live="polite" class="gx-count"></p>
    </div>
  </div>
</article>
