---
import { PROJECTS, pad, sheetPath } from '../data/projects';
import YouTubePlayer from './YouTubePlayer.astro';
---
{PROJECTS.map((p, i) => (
<article aria-hidden="true" class="room" id={`room-${p.id}`}>
<div class="room-scroll">
<header class="room-top">
<button class="back" onclick="closeRoom()">&larr; Back</button>
<span class="room-num">{pad(i + 1)} / {pad(PROJECTS.length)}</span>
</header>
<div class="room-body">
<div class="room-intro">
<h2 class="room-title">{p.title}</h2>
<p class="room-desc">{p.desc}</p>
<div class="dmeta">
{p.meta.map((row) => (
<div class="drow"><span class="dk">{row.k}</span><span>{row.v}</span></div>
))}
</div>
</div>
<div class="sheets">
{p.sheets.map((file, j) => (
<figure class="sheet">
<img
  alt={`${p.title} — portfolio sheet ${j + 1} of ${p.sheets.length}`}
  decoding="async"
  loading={j === 0 ? "eager" : "lazy"}
  src={sheetPath(p, file)}
/>
</figure>
))}
</div>
{p.video && <YouTubePlayer videoId={p.video.youtubeId} title={p.video.title} poster={p.video.poster} />}
<button class="nextp" onclick={`nextRoom('${p.id}')`}>Next project &rarr;</button>
</div>
</div>
</article>
))}
