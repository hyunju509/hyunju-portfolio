---
// Redirect /info to /about
const response = Astro.response;
response.status = 301;
response.headers.set('Location', '/about');
---
<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title>Redirecting...</title>
<meta http-equiv="refresh" content="0;url=/about">
</head>
<body></body>
</html>
