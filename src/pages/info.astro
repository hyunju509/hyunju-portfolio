---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InfoLedger from '../components/InfoLedger.astro';

const education = [
  {
    key: "2025.05 — 2026.05",
    main: ["Columbia University GSAPP", "M.S. Advanced Architectural Design", "New York, United States"],
    detail: ["High Pass Studio Work:", "Fluid Terrain", "Shadow Archive", "Ivanpah Solar Sanctuary"],
  },
  {
    key: "2019.03 — 2025.02",
    main: ["Kookmin University", "B.Arch, Architectural Design", "Seoul, Korea"],
    detail: ["GPA 4.26 / 4.5", "Graduated 2nd in Class"],
  },
  {
    key: "2021 — 2022",
    main: ["RMIT University", "Exchange Program in Architecture", "Melbourne, Australia"],
  },
];

const projects = [
  {
    key: "Calibrated Environment",
    main: ["New York, NY", "40-Story Mixed-Use Tower"],
    detail: ["Revit + Ladybug"],
  },
  {
    key: "Fluid Terrain",
    main: ["Santa Paula Creek, CA", "Hydrological Landscape Infrastructure"],
    detail: ["Material Ecology + Passive Cooling"],
  },
  {
    key: "Ordinary Village: Hide and Seek",
    main: ["Seoul, Korea", "Interactive Residential Village"],
    detail: ["Adaptive Domestic Space"],
  },
  {
    key: "Surreal Museum Tower",
    main: ["New York, NY", "Vertical Museum Prototype"],
    detail: ["Spatial Sequence + Facade Study"],
  },
  {
    key: "Shadow Archive: Inverse Preserve",
    main: ["Churchill, Canada", "Environmental Research Archive"],
    detail: ["Climate Research + Sectional Design"],
  },
];

const awards = [
  { key: "2026.05", main: ["GSAPP End of Year Show"], detail: ["Fluid Terrain"] },
  { key: "2025.07", main: ["Climate - Models - Images, New York"], detail: ["Ivanpah Solar Sanctuary"] },
  { key: "2024.07", main: ["Sensory Museum"], detail: ["Surreal Museum Tower", "Honorable Mention"] },
  { key: "2022.11", main: ["Fondation Jacques Rougerie"], detail: ["Focus Space Prize"] },
  { key: "2021.02", main: ["Sejong National Pilot Smart City Design Competition"], detail: ["5th Prize"] },
  { key: "2019.12", main: ["Dokdo Guesthouse Design International Competition"], detail: ["Excellence Award"] },
];

const skillGroups = [
  { title: "Modeling & BIM", items: ["Rhinoceros", "Revit", "AutoCAD"] },
  { title: "Computation & Analysis", items: ["Grasshopper", "Python", "QGIS", "Ladybug", "CFD Simulation"] },
  { title: "Visualization", items: ["V-Ray", "D5 Render", "Enscape", "Unreal Engine"] },
  { title: "Adobe Suite", items: ["Photoshop", "Illustrator", "InDesign", "After Effects", "Premiere Pro"] },
  { title: "Fabrication", items: ["Laser Cutting", "3D Printing", "Digital Fabrication"] },
  { title: "Additional", items: ["Environmental Analysis", "Diagramming", "Presentation Layouts"] },
];
---
<BaseLayout title="Info — Hyunju Kim">
<Header />
<main class="info-page">

<section class="info-section info-intro-section">
<div class="info-sec-head">
<span class="info-num">01</span>
<span class="info-eyebrow">Introduction</span>
</div>
<div class="info-intro">
<h1 class="info-title">Info</h1>
<div class="info-bio">
<p>Hyunju Kim is an architectural designer based in New York and a recent graduate of Columbia GSAPP&rsquo;s M.S. in Advanced Architectural Design program. Her work explores relationships between environmental performance, material systems, and spatial experience across architectural and landscape scales.</p>
<p>Her work combines Revit and Rhino-based design development with environmental analysis, computational workflows, visualization, and architectural documentation. Recent projects examine climate-responsive mixed-use towers, flood-adaptive landscape infrastructure, adaptive domestic environments, and environmental research archives.</p>
<p>She holds a B.Arch from Kookmin University and is a LEED AP BD+C.</p>
<ul class="info-facts">
<li>New York, NY</li>
<li><a href="mailto:hyunju.kim.0509@gmail.com">hyunju.kim.0509@gmail.com</a></li>
<li>LEED AP BD+C</li>
</ul>
</div>
</div>
</section>

<InfoLedger num="02" title="Education" rows={education} />
<InfoLedger num="03" title="Selected Projects" rows={projects} />
<InfoLedger num="04" title="Awards &amp; Exhibitions" rows={awards} />

<section class="info-section">
<div class="info-sec-head">
<span class="info-num">05</span>
<h2 class="info-h2">Skills &amp; Credentials</h2>
</div>
<div class="skills-grid">
{skillGroups.map((g) => (
  <div class="skill-group">
    <h3 class="skill-title">{g.title}</h3>
    <ul>
      {g.items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
))}
</div>
<div class="credential">
<span class="credential-name">LEED AP BD+C</span>
<span class="credential-date">2026.06</span>
</div>
</section>

<section class="info-section info-contact-section">
<h2 class="info-h2">Contact</h2>
<div class="info-contact">
<span>New York, NY</span>
<a href="mailto:hyunju.kim.0509@gmail.com">hyunju.kim.0509@gmail.com</a>
<a class="viewwork" href="/#work">Work<span aria-hidden="true">&nbsp;&rarr;</span></a>
</div>
</section>

</main>
<Footer />
</BaseLayout>
