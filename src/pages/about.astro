---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InfoLedger from '../components/InfoLedger.astro';
import AwardsLedger from '../components/AwardsLedger.astro';
import { getAboutContent } from '../lib/sanity/content';

/* Sanity (published) — the About singleton reproduces the legacy shapes. */
const about = await getAboutContent();
const { education, selectedProjects: projects, awards, skillGroups } = about;
---
<BaseLayout title="About — Hyunju Kim">
<Header />
<main class="info-page">

<section class="info-section info-intro-section">
<div class="info-sec-head">
<span class="info-num">01</span>
<span class="info-eyebrow">Introduction</span>
</div>
<div class="info-intro">
<h1 class="info-title">About</h1>
<div class="info-bio">
{about.introduction.map((p) => <p>{p}</p>)}
<ul class="info-facts">
{about.location && <li>{about.location}</li>}
<li><a href={`mailto:${about.email}`}>{about.email}</a></li>
{about.credential?.name && <li>{about.credential.name}</li>}
</ul>
</div>
</div>
</section>

<InfoLedger num="02" title="Education" rows={education} />
<InfoLedger num="03" title="Selected Projects" rows={projects} />
<AwardsLedger num="04" rows={awards} />

<section class="info-section">
<div class="info-sec-head">
<span class="info-num">05</span>
<h2 class="info-h2">Skills &amp; Credentials</h2>
</div>
<div class="skills-grid">
{skillGroups.map((g) => (
  <div class="skill-group">
    <h3 class="skill-title">{g.title}</h3>
    <ul>
      {g.items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
))}
</div>
{about.credential?.name && (
<div class="credential">
<span class="credential-name">{about.credential.name}</span>
<span class="credential-date">{about.credential.date}</span>
</div>
)}
</section>

<section class="info-section info-contact-section">
<h2 class="info-h2">Contact</h2>
<div class="info-contact">
{about.location && <span>{about.location}</span>}
<a href={`mailto:${about.email}`}>{about.email}</a>
<a class="viewwork" href="/">Work<span aria-hidden="true">&nbsp;&rarr;</span></a>
</div>
</section>

</main>
<Footer />
</BaseLayout>
