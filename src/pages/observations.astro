---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getObservationsData, getSiteSettings } from '../lib/sanity/content';

/* Sanity (published) — reproduces the exact legacy registry shapes. */
const { locations: OBSERVATION_LOCATIONS, studies: IMAGE_STUDIES, categories: IMAGE_STUDY_CATEGORIES } =
  await getObservationsData();
const settings = await getSiteSettings();

const EAGER_COUNT = 8; // covers the widest first-row column count (7) plus one
let renderedIndex = 0;
let studiesRenderedIndex = 0;

const studyCategoryCounts = Object.fromEntries(
  IMAGE_STUDY_CATEGORIES.map((c) => [c.slug, IMAGE_STUDIES.filter((s) => s.category === c.slug).length])
);
const studyCategoryTitles = Object.fromEntries(IMAGE_STUDY_CATEGORIES.map((c) => [c.slug, c.title]));
---
<BaseLayout title="Observations — Hyunju Kim">
<Header />
<main class="observations-page">

<section class="observations-intro">
<h1>Observations</h1>
<p>{settings.observationsIntro}</p>
</section>

<nav class="obs-subnav" aria-label="Observations sections">
  <a class="obs-subnav-link" data-target="places" href="#places">{settings.placesLabel ?? 'Places'}</a>
  <a class="obs-subnav-link" data-target="writing" href="#writing">{settings.writingLabel ?? 'Writing'}</a>
  <a class="obs-subnav-link" data-target="image-studies" href="#image-studies">{settings.imageStudiesLabel ?? 'Image Studies'}</a>
</nav>

<section class="observations-section" id="places">
<h2>{settings.placesLabel ?? 'Places'}</h2>
<p>{settings.placesIntro}</p>

<div class="obs-filters" role="group" aria-label="Filter photographs by location">
  <button class="obs-filter" data-slug="all" aria-pressed="true" type="button">All</button>
  {OBSERVATION_LOCATIONS.map((loc) => (
    <button class="obs-filter" data-slug={loc.slug} aria-pressed="false" type="button">{loc.title}</button>
  ))}
</div>

<div class="obs-grid">
{OBSERVATION_LOCATIONS.flatMap((loc) =>
  loc.images.map((img) => {
    const eager = renderedIndex < EAGER_COUNT;
    renderedIndex++;
    return (
      <button
        class="obs-tile"
        type="button"
        data-slug={loc.slug}
        data-full={img.full}
        data-title={loc.title}
        data-seq={img.seq}
        data-count={loc.imageCount}
        data-width={img.width}
        data-height={img.height}
        aria-label={`Open photograph ${img.seq} from ${loc.title}`}
      >
        <img
          src={img.thumb}
          alt=""
          width="600"
          height="600"
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
        />
      </button>
    );
  })
)}
</div>
</section>

<section class="observations-section observations-writing" id="writing">
<h2>{settings.writingLabel ?? 'Writing'}</h2>
<p>{settings.writingIntro}</p>
<a class="obs-writing-link" href="/observations/writing">Read {settings.writingLabel ?? 'Writing'} <span aria-hidden="true">&rarr;</span></a>
</section>

<section class="observations-section" id="image-studies">
<h2>{settings.imageStudiesLabel ?? 'Image Studies'}</h2>
<p>{settings.imageStudiesIntro}</p>

<div class="obs-categories-legend">
{IMAGE_STUDY_CATEGORIES.map((cat) => (
  <div class="obs-category-blurb">
    <h3>{cat.title}</h3>
    <p>{cat.description}</p>
  </div>
))}
</div>

<div class="obs-filters" role="group" aria-label="Filter image studies by category">
  <button class="obs-filter" data-category="all" aria-pressed="true" type="button">All</button>
  {IMAGE_STUDY_CATEGORIES.map((cat) => (
    <button class="obs-filter" data-category={cat.slug} aria-pressed="false" type="button">{cat.title}</button>
  ))}
</div>

<div class="obs-grid">
{IMAGE_STUDIES.map((item) => {
  const eager = studiesRenderedIndex < EAGER_COUNT;
  studiesRenderedIndex++;
  const title = studyCategoryTitles[item.category];
  const count = studyCategoryCounts[item.category];
  return (
    <button
      class="obs-tile"
      type="button"
      data-category={item.category}
      data-full={item.full}
      data-title={title}
      data-seq={item.seq}
      data-count={count}
      data-width={item.width}
      data-height={item.height}
      aria-label={`Open ${title} image ${item.seq}`}
    >
      <img
        src={item.thumb}
        alt=""
        width="600"
        height="600"
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
      />
      <span class="obs-tile-label" aria-hidden="true">{title}</span>
    </button>
  );
})}
</div>
</section>

</main>
<Footer />

<div class="obs-viewer" id="obs-viewer" hidden role="dialog" aria-modal="true" aria-label="Photograph viewer">
  <button class="obs-viewer-close" type="button" aria-label="Close photograph viewer">Close</button>
  <button class="obs-viewer-prev" type="button" aria-label="Previous photograph">&larr;</button>
  <div class="obs-viewer-frame">
    <img alt="" />
  </div>
  <button class="obs-viewer-next" type="button" aria-label="Next photograph">&rarr;</button>
  <p class="obs-viewer-caption" aria-live="polite"></p>
</div>

</BaseLayout>

<script>
  import '../scripts/observations-gallery';
</script>

<style>
.observations-page {
  padding: 120px 4vw;
  max-width: 1200px;
  margin: 0 auto;
  /* Places' lazily-loaded images sit above Writing/Image Studies; browser
     scroll anchoring can silently re-adjust scroll position as their layout
     settles, fighting a hash-driven scrollIntoView() on initial load. */
  overflow-anchor: none;
}

.observations-intro {
  margin-bottom: 40px;
}

.observations-intro h1,
.observations-section h2 {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  letter-spacing: -0.01em;
}

.observations-intro h1 {
  font-size: clamp(40px, 6vw, 64px);
  margin-bottom: 24px;
  letter-spacing: -0.02em;
}

.observations-intro p {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 1.0625rem;
  line-height: 1.6;
  max-width: 600px;
  color: rgba(0, 0, 0, 0.7);
}

/* ---------- local section navigation ---------- */
.obs-subnav {
  display: flex;
  gap: 20px;
  margin-bottom: 64px;
  padding: 10px 0;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.obs-subnav::-webkit-scrollbar {
  display: none;
}

.obs-subnav-link {
  flex: 0 0 auto;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.02em;
  white-space: nowrap;
  color: rgba(0, 0, 0, 0.5);
  padding: 2px 0;
  border-bottom: 1px solid transparent;
  transition: color 0.2s ease-out, border-color 0.2s ease-out;
}

.obs-subnav-link:hover {
  color: #111;
}

.obs-subnav-link.active {
  color: #111;
  border-bottom-color: #111;
}

.obs-subnav-link:focus-visible {
  outline: 2px solid #111;
  outline-offset: 3px;
}

@media (min-width: 1024px) {
  .obs-subnav {
    position: sticky;
    top: 84px;
    z-index: 20;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(2px);
  }
}

.observations-section {
  margin-bottom: 60px;
  scroll-margin-top: 96px;
}

.observations-section h2 {
  font-size: clamp(20px, 2.2vw, 26px);
  margin-bottom: 12px;
}

.observations-section p {
  font-family: 'Archivo', sans-serif;
  font-weight: 400;
  font-size: 0.95rem;
  line-height: 1.6;
  color: rgba(0, 0, 0, 0.6);
}

.obs-writing-link {
  display: inline-block;
  margin-top: 14px;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.02em;
  color: #111;
  border-bottom: 1px solid rgba(0, 0, 0, 0.3);
}

.obs-writing-link:hover {
  border-bottom-color: #111;
}

.obs-writing-link:focus-visible {
  outline: 2px solid #111;
  outline-offset: 3px;
}

/* ---------- image studies category legend ---------- */
.obs-categories-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 24px 48px;
  margin: 28px 0 8px;
}

.obs-category-blurb {
  max-width: 320px;
}

.obs-category-blurb h3 {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 13.5px;
  letter-spacing: 0.02em;
  color: #111;
  margin-bottom: 4px;
}

.obs-category-blurb p {
  font-family: 'Archivo', sans-serif;
  font-weight: 400;
  font-size: 0.85rem;
  line-height: 1.55;
  color: rgba(0, 0, 0, 0.55);
}

/* ---------- location filter ---------- */
.obs-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 18px;
  margin: 28px 0 32px;
}

.obs-filter {
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.02em;
  color: rgba(0, 0, 0, 0.5);
  padding: 2px 0;
  border-bottom: 1px solid transparent;
}

.obs-filter:hover {
  color: #111;
}

.obs-filter[aria-pressed="true"] {
  color: #111;
  border-bottom-color: #111;
}

.obs-filter:focus-visible {
  outline: 2px solid #111;
  outline-offset: 3px;
}

/* ---------- square contact-sheet grid ---------- */
.obs-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10px;
}

@media (min-width: 1600px) {
  .obs-grid { grid-template-columns: repeat(7, 1fr); }
}
@media (max-width: 1024px) {
  .obs-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; }
}
@media (max-width: 640px) {
  .obs-grid { grid-template-columns: repeat(2, 1fr); gap: 6px; }
}

.obs-tile {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #f2f2ee;
  padding: 0;
  border: none;
}

.obs-tile[hidden] { display: none; }

.obs-tile img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.2s ease-out;
}

.obs-tile:hover img,
.obs-tile:focus-visible img {
  opacity: 0.85;
}

.obs-tile:focus-visible {
  outline: 2px solid #111;
  outline-offset: -2px;
}

.obs-tile-label {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 6px 8px;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 11px;
  letter-spacing: 0.03em;
  color: #fff;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.2s ease-out, transform 0.2s ease-out;
  pointer-events: none;
}

.obs-tile:hover .obs-tile-label,
.obs-tile:focus-visible .obs-tile-label {
  opacity: 1;
  transform: translateY(0);
}

/* ---------- full-image viewer ---------- */
.obs-viewer {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: #fafaf8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 5vw 48px;
  opacity: 0;
  transition: opacity 220ms ease-out;
}

.obs-viewer.open { opacity: 1; }
.obs-viewer[hidden] { display: none; }

.obs-viewer-frame {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.obs-viewer-frame img {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
}

.obs-viewer-close,
.obs-viewer-prev,
.obs-viewer-next {
  position: absolute;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 13px;
  letter-spacing: 0.03em;
  color: rgba(0, 0, 0, 0.55);
  z-index: 2;
}

.obs-viewer-close {
  top: 20px;
  right: 5vw;
}

.obs-viewer-prev,
.obs-viewer-next {
  top: 50%;
  transform: translateY(-50%);
  font-size: 22px;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.obs-viewer-prev { left: 1vw; }
.obs-viewer-next { right: 1vw; }

.obs-viewer-close:hover,
.obs-viewer-prev:hover,
.obs-viewer-next:hover {
  color: #111;
}

.obs-viewer-close:focus-visible,
.obs-viewer-prev:focus-visible,
.obs-viewer-next:focus-visible {
  outline: 2px solid #111;
  outline-offset: 2px;
}

.obs-viewer-prev:disabled,
.obs-viewer-next:disabled {
  opacity: 0.25;
  pointer-events: none;
}

.obs-viewer-caption {
  margin-top: 18px;
  font-family: 'Archivo', sans-serif;
  font-weight: 300;
  font-size: 12.5px;
  letter-spacing: 0.04em;
  color: rgba(0, 0, 0, 0.55);
  font-variant-numeric: tabular-nums;
}

:global(body.obs-viewer-lock) {
  position: fixed;
  left: 0;
  right: 0;
  overflow-y: scroll;
}

@media (prefers-reduced-motion: reduce) {
  .obs-viewer { transition: none; }
  .obs-tile img { transition: none; }
  .obs-tile-label { transition: none; }
  .obs-subnav-link { transition: none; }
}
</style>
