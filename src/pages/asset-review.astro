---
// Internal, local-only asset triage page. Reads the manifest generated by
// _asset-tools/build-organized.mjs + build-thumbs-manifest.mjs. Not linked
// from navigation. Manifest and thumbnails are gitignored (see .gitignore:
// _asset-inbox/, _asset-organized/, public/_asset-review-thumbs/), so on a
// fresh checkout without having run the asset-tools scripts this page
// renders an empty-state message instead of failing the build.
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const manifestPath = path.join(process.cwd(), '_asset-organized/asset-manifest.json');
let rows = [];
if (fs.existsSync(manifestPath)) {
  rows = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));
}

const PROJECT_LABELS = {
  'fluid-terrain': 'Fluid Terrain',
  'calibrated-environment': 'Calibrated Environment',
  'surreal-museum': 'Surreal Museum Tower',
  'spectrum-living': 'Spectrum Living',
  'shadow-archive': 'Shadow Archive: Inverse Preserve',
  'ordinary-village': 'Ordinary Village: Hide and Seek',
  'ivanpah-solar-sanctuary': 'Ivanpah Solar Sanctuary',
  'space-urchin': 'Space Urchin',
  'floating-microhabitat': 'Floating Microhabitat',
  'terroir-hot-springs': 'Terroir Hot Springs',
  'playful-layers': 'Playful Layers',
  'hora-museum': 'Hora Museum',
  'threshold-housing': 'Threshold Housing',
  'w-school': 'W-School',
  'sejong-smart-school': 'Sejong Smart School',
  'supplementary': 'Supplementary (uncategorized)',
  '_unresolved': 'Unresolved',
};

const PROJECT_ORDER = [
  'fluid-terrain', 'calibrated-environment', 'surreal-museum', 'spectrum-living',
  'shadow-archive', 'ordinary-village', 'ivanpah-solar-sanctuary',
  'floating-microhabitat', 'space-urchin', 'terroir-hot-springs', 'playful-layers',
  'hora-museum', 'threshold-housing', 'w-school', 'sejong-smart-school',
  'supplementary', '_unresolved',
];

const classified = rows.filter(r => r.assignedProject !== '_unresolved' && r.assignedType !== 'unsupported-format' && r.assignedType !== 'render-error');
const unresolved = rows.filter(r => r.assignedProject === '_unresolved' && r.assignedType !== 'unsupported-format' && r.assignedType !== 'render-error');
const errored = rows.filter(r => r.assignedType === 'unsupported-format' || r.assignedType === 'render-error');

const byProject = {};
for (const r of classified) {
  if (!byProject[r.assignedProject]) byProject[r.assignedProject] = [];
  byProject[r.assignedProject].push(r);
}
for (const proj of Object.keys(byProject)) {
  byProject[proj].sort((a, b) => {
    const confRank = { HIGH: 0, MEDIUM: 1, LOW: 2 };
    const ca = confRank[a.confidence] ?? 3, cb = confRank[b.confidence] ?? 3;
    if (ca !== cb) return ca - cb;
    return (a.proposedSequence || 99) - (b.proposedSequence || 99);
  });
}

const dupGroupIds = new Set();
for (const r of rows) {
  if (r.exactDupGroup) dupGroupIds.add(r.exactDupGroup);
  if (r.nearDupGroup) dupGroupIds.add(r.nearDupGroup);
}
const dupGroups = {};
for (const r of rows) {
  if (r.exactDupGroup) {
    (dupGroups[r.exactDupGroup] ||= []).push(r);
  }
  if (r.nearDupGroup) {
    (dupGroups[r.nearDupGroup] ||= []).push(r);
  }
}

const summary = {
  total: rows.length,
  classified: classified.length,
  high: classified.filter(r => r.confidence === 'HIGH').length,
  medium: classified.filter(r => r.confidence === 'MEDIUM').length,
  low: classified.filter(r => r.confidence === 'LOW').length,
  unresolved: unresolved.length,
  errored: errored.length,
  dupGroups: Object.keys(dupGroups).length,
};
---
<BaseLayout title="Asset Review — Internal">
<main class="ar-page">
  <div class="ar-banner">
    <strong>INTERNAL ASSET REVIEW</strong>
    <span>NOT FOR PUBLIC NAVIGATION</span>
  </div>

  {rows.length === 0 && (
    <p class="ar-empty">
      No manifest found at <code>_asset-organized/asset-manifest.json</code>.
      Run the asset-tools scripts in <code>_asset-tools/</code> against
      <code>_asset-inbox/</code> to generate it.
    </p>
  )}

  {rows.length > 0 && (
  <>
  <section class="ar-summary">
    <h1>Asset Classification Review</h1>
    <p>
      {summary.total} source files scanned &middot; {summary.classified} classified into projects
      ({summary.high} HIGH, {summary.medium} MEDIUM, {summary.low} LOW confidence) &middot;
      {summary.unresolved} unresolved &middot; {summary.errored} unreadable/unsupported &middot;
      {summary.dupGroups} duplicate groups
    </p>
    <p class="ar-howto">
      To approve, reply with review IDs, e.g.: "Approve all HIGH confidence items."
      "Move MX-014 to Shadow Archive." "Use FT-023 as the Fluid Terrain hero." "Exclude CE-031."
    </p>
  </section>

  {PROJECT_ORDER.filter(p => byProject[p]).map((proj) => (
    <section class="ar-project">
      <h2>{PROJECT_LABELS[proj] || proj} <span class="ar-count">({byProject[proj].length})</span></h2>

      {['HIGH', 'MEDIUM', 'LOW'].map((conf) => {
        const items = byProject[proj].filter(r => r.confidence === conf);
        if (!items.length) return null;
        return (
          <div class="ar-conf-group">
            <h3 class={`ar-conf-label ar-conf-${conf.toLowerCase()}`}>{conf} confidence ({items.length})</h3>
            <div class="ar-grid">
              {items.map((r) => (
                <div class="ar-card" data-status={r.recommendedStatus}>
                  <div class="ar-thumb">
                    {r.thumbPath && <img src={r.thumbPath} alt={r.originalFilename} loading="lazy" />}
                  </div>
                  <div class="ar-meta">
                    <div class="ar-id">{r.reviewId}</div>
                    <div class="ar-filename" title={r.originalFilename}>{r.originalFilename}</div>
                    {r.renamedFile && <div class="ar-renamed" title={r.renamedFile}>{r.renamedFile.split('/').pop()}</div>}
                    <div class="ar-tags">
                      <span class="ar-tag">{r.assignedType}</span>
                      <span class="ar-tag">seq {r.proposedSequence ?? '—'}</span>
                      <span class={`ar-tag ar-status-${r.recommendedStatus}`}>{r.recommendedStatus}</span>
                    </div>
                    <div class="ar-reason">{r.reason}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  ))}

  <section class="ar-project ar-dupgroups">
    <h2>Duplicate Groups <span class="ar-count">({Object.keys(dupGroups).length})</span></h2>
    <div class="ar-dup-list">
      {Object.entries(dupGroups).map(([gid, items]) => (
        <div class="ar-dup-group">
          <div class="ar-dup-gid">{gid}</div>
          <div class="ar-grid">
            {items.map((r) => (
              <div class="ar-card ar-card-small" data-preferred={r.isPreferredInGroup}>
                <div class="ar-thumb">
                  {r.thumbPath && <img src={r.thumbPath} alt={r.originalFilename} loading="lazy" />}
                </div>
                <div class="ar-meta">
                  <div class="ar-id">{r.reviewId} {r.isPreferredInGroup && <span class="ar-preferred-badge">preferred</span>}</div>
                  <div class="ar-filename" title={r.originalFilename}>{r.originalFilename}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="ar-project">
    <h2>Unresolved <span class="ar-count">({unresolved.length})</span></h2>
    <div class="ar-grid">
      {unresolved.map((r) => (
        <div class="ar-card">
          <div class="ar-thumb">
            {r.thumbPath && <img src={r.thumbPath} alt={r.originalFilename} loading="lazy" />}
          </div>
          <div class="ar-meta">
            <div class="ar-id">{r.reviewId}</div>
            <div class="ar-filename" title={r.originalFilename}>{r.originalFilename}</div>
            <div class="ar-reason">{r.reason}</div>
          </div>
        </div>
      ))}
    </div>
  </section>

  {errored.length > 0 && (
  <section class="ar-project">
    <h2>Unreadable / Unsupported <span class="ar-count">({errored.length})</span></h2>
    <ul class="ar-error-list">
      {errored.map((r) => (
        <li><strong>{r.reviewId}</strong> {r.originalFilename} — {r.reason}</li>
      ))}
    </ul>
  </section>
  )}
  </>
  )}
</main>
</BaseLayout>

<style>
.ar-page { max-width: 1400px; margin: 0 auto; padding: 0 24px 120px; }
.ar-banner {
  position: sticky; top: 0; z-index: 10;
  background: #b91c1c; color: #fff;
  padding: 10px 24px; margin: 0 -24px 32px;
  display: flex; gap: 12px; align-items: baseline; flex-wrap: wrap;
  font-size: 13px; letter-spacing: 0.04em;
}
.ar-banner strong { font-size: 14px; }
.ar-empty { padding: 80px 0; font-size: 14px; color: #555; }
.ar-summary { margin: 24px 0 40px; }
.ar-summary h1 { font-size: 22px; margin: 0 0 8px; }
.ar-summary p { font-size: 13px; color: #444; margin: 4px 0; }
.ar-howto { font-family: monospace; background: #f5f5f0; padding: 8px 12px; }

.ar-project { margin: 48px 0; padding-top: 24px; border-top: 1px solid #ddd; }
.ar-project h2 { font-size: 18px; margin: 0 0 16px; }
.ar-count { color: #888; font-weight: normal; font-size: 14px; }
.ar-conf-group { margin: 16px 0 28px; }
.ar-conf-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 10px; padding: 3px 8px; display: inline-block; border-radius: 2px; }
.ar-conf-high { background: #dcfce7; color: #166534; }
.ar-conf-medium { background: #fef9c3; color: #854d0e; }
.ar-conf-low { background: #fee2e2; color: #991b1b; }

.ar-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 14px; }
.ar-card { border: 1px solid #e5e5e0; background: #fff; font-size: 11px; }
.ar-card-small { font-size: 10px; }
.ar-thumb { aspect-ratio: 4/3; background: #f2f2ee; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.ar-thumb img { max-width: 100%; max-height: 100%; object-fit: contain; }
.ar-meta { padding: 8px; }
.ar-id { font-family: monospace; font-weight: bold; font-size: 11px; }
.ar-filename { color: #666; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin: 2px 0; }
.ar-renamed { color: #1d4ed8; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin: 2px 0; }
.ar-tags { display: flex; gap: 4px; flex-wrap: wrap; margin: 4px 0; }
.ar-tag { background: #f0f0eb; padding: 1px 6px; border-radius: 2px; font-size: 10px; }
.ar-status-duplicate { background: #fecaca; }
.ar-status-reject-from-website { background: #e5e5e5; color: #666; }
.ar-status-primary { background: #bbf7d0; }
.ar-reason { color: #888; font-size: 10px; margin-top: 4px; line-height: 1.4; }

.ar-dup-list { display: flex; flex-direction: column; gap: 20px; }
.ar-dup-group { border: 1px dashed #ccc; padding: 12px; }
.ar-dup-gid { font-family: monospace; font-size: 12px; margin-bottom: 8px; color: #444; }
.ar-preferred-badge { background: #166534; color: #fff; font-size: 9px; padding: 1px 5px; border-radius: 2px; margin-left: 4px; }

.ar-error-list { font-size: 12px; line-height: 1.8; color: #666; }
</style>
