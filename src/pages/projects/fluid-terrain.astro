---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
---
<BaseLayout title="Fluid Terrain — Hyunju Kim">
<Header />

<div class="ftp" id="ftp">

<!-- ======================= 00 OPENING FRAME ======================= -->
<section class="act opening">
  <aside class="open-rail fx">
    <h1 class="open-title">Fluid<br />Terrain</h1>
    <dl class="open-meta">
      <div><dt>Location</dt><dd>Santa Paula Creek<br />Ventura County, California</dd></div>
      <div><dt>Year</dt><dd>2026</dd></div>
      <div><dt>Program</dt><dd>Hydrological Landscape Infrastructure</dd></div>
      <div><dt>Team</dt><dd>Individual Project</dd></div>
      <div><dt>Instructor</dt><dd>Marc Tsurumaki</dd></div>
      <div><dt>Key Words</dt><dd>Flood Mitigation<br />Porous Ground<br />Thermal Microclimate<br />Seasonal Habitat</dd></div>
    </dl>
  </aside>

  <figure class="open-media fx">
    <img
      src="/images/fluid-03.jpg" width="1500" height="815"
      alt="Fluid Terrain — the same gabion and timber structures in the dry season and under winter rain, showing the architecture across two water conditions"
      fetchpriority="high" />
  </figure>

  <div class="open-text fx">
    <p class="open-lead">Architecture becomes a porous landscape system that slows water and supports seasonal habitation.</p>
    <p class="open-body">Located along the urban–agricultural edge of Santa Paula Creek, the project responds to increasing flood intensity and accelerated water velocity through a distributed gabion landscape system and porous infrastructure.</p>
  </div>
</section>

<!-- ======================= 01 CONDITION ======================= -->
<section class="act act-01">
  <div class="ch-rail">
    <span class="ch-num fx">01 — Condition</span>
  </div>
  <div class="ch-body">
    <h2 class="ch-title fx">Where water accelerates between the city and farmland</h2>
    <figure class="sheet sheet-right fx">
      <img
        src="/images/portfolio-pages/fluid-terrain/01-fluid-03.jpg" width="1372" height="896"
        alt="Site analysis sheet — seasonal cycle diagram of precipitation, flood pressure, and agricultural intensity in Santa Paula Creek, with hydrological and crop maps of the creek corridor"
        loading="lazy" decoding="async" />
    </figure>
    <p class="ch-text ch-text-left fx">Santa Paula Creek forms a shifting boundary between urban development and farmland, where seasonal floods accelerate erosion, displace material, and intensify ecological pressure.</p>
  </div>
</section>

<!-- ======================= 02 POROUS GROUND ======================= -->
<section class="act act-02">
  <div class="ch-rail">
    <span class="ch-num fx">02 — Porous Ground</span>
  </div>
  <div class="ch-body">
    <h2 class="ch-title fx">Slowing the creek through porous ground</h2>
    <p class="ch-text ch-text-offset fx">Buildings rise from porous gabion foundations that slow water flow and stabilize the creek edge.</p>
    <figure class="sheet sheet-wide fx">
      <img
        src="/images/portfolio-pages/fluid-terrain/01-fluid-05.jpg" width="1372" height="896"
        alt="Long architectural section through the porous gabion landscape — market, cooling storage, filtering system, and fish ladder terraces stepping down to the creek, with summer dry-season and winter flood-season studies below"
        loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<!-- ======================= 03 MATERIAL CYCLE ======================= -->
<section class="act act-03">
  <aside class="side-rail">
    <span class="ch-num fx">03 — Material Cycle</span>
    <h2 class="ch-title-s fx">How materials return as cooling ground</h2>
    <p class="ch-text-s fx">Recycled concrete, timber, hemp lime, and thatch operate through different cycles of use, weathering, and renewal, allowing the architecture to adapt as ground and climate conditions change.</p>
  </aside>
  <figure class="sheet sheet-tech fx">
    <img
      src="/images/portfolio-pages/fluid-terrain/01-fluid-04.jpg" width="1372" height="896"
      alt="Material strategy sheet — aerial drawing of the gabion settlement in the creek, material cycle diagram from waste concrete to porous gabion foundations, and gabion wall assembly details"
      loading="lazy" decoding="async" />
  </figure>
</section>

<!-- ======================= 04 SEASONAL TRANSFORMATION ======================= -->
<section class="act act-04">
  <div class="ch-head">
    <span class="ch-num fx">04 — Seasonal Transformation</span>
    <h2 class="ch-title fx">Flood cycles and droughts</h2>
  </div>
  <div class="season-pair">
    <figure class="season-a fx">
      <img
        src="/images/fluid-01.jpg" width="860" height="1347"
        alt="Dry season — thatched timber structures standing on exposed ground beside the empty creek bed"
        loading="lazy" decoding="async" />
      <figcaption>Summer — dry season</figcaption>
    </figure>
    <figure class="season-b fx">
      <img
        src="/images/fluid-08.jpg" width="860" height="860"
        alt="Flood season — the same terraces under winter rain with water rising through the gabion ground"
        loading="lazy" decoding="async" />
      <figcaption>Winter — flood season</figcaption>
    </figure>
  </div>
  <p class="ch-text season-text fx">As water levels shift, different terraces become accessible, supporting seasonal occupation and habitat.</p>
</section>

<!-- ======================= 05 LIVING WITH WATER ======================= -->
<section class="act act-05">
  <div class="ch-rail">
    <span class="ch-num fx">05 — Living with Water</span>
  </div>
  <div class="ch-body">
    <h2 class="ch-title fx">Occupied terraces along the creek edge</h2>
    <figure class="sheet sheet-live fx">
      <img
        src="/images/portfolio-pages/fluid-terrain/01-fluid-02.jpg" width="1372" height="896"
        alt="Occupation sheet — a seasonal market on the timber deck between gabion walls, and a view of the settlement's stepped terraces meeting the creek"
        loading="lazy" decoding="async" />
    </figure>
    <p class="ch-text ch-text-left fx">Concrete debris is repurposed as distributed gabion terraces that slow water flow, create shaded microclimates, and support seasonal markets, storage areas, and workshops.</p>
  </div>
  <div class="peek-wrap">
    <figure class="peek fx">
      <img
        src="/images/fluid-06.jpg" width="1100" height="496"
        alt="The gabion settlement seen along the creek, terraces dissolving into the water and the orchard landscape beyond"
        loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<!-- ======================= 06 CLOSING ======================= -->
<section class="act closing">
  <div class="close-inner fx">
    <span class="ch-num">Next Project</span>
    <a class="next-link" href="/#work">Calibrated Environment &rarr;</a>
    <a class="back-link" href="/#work">&larr; Back to Work</a>
  </div>
</section>

</div>

<style is:global>
/* ---- Fluid Terrain prototype (route-scoped under .ftp) ---- */
.ftp{background:#fff;color:var(--ink);overflow-x:clip;}
.ftp .ch-num{display:block;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray2);}
.ftp .ch-title{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(22px,2.4vw,32px);line-height:1.15;letter-spacing:-.01em;max-width:560px;}
.ftp .ch-text{font-size:14px;line-height:1.7;color:#3a3a3a;max-width:400px;}
.ftp figure{margin:0;}
.ftp img{display:block;width:100%;height:auto;}
.ftp .sheet img{border:1px solid rgba(0,0,0,.05);box-shadow:0 1px 1px rgba(0,0,0,.03),0 12px 28px -18px rgba(0,0,0,.16);}

/* reveal motion — active only when .ftp-motion set by script */
.ftp.ftp-motion .fx{opacity:.85;transform:translateY(10px) scale(.988);transition:opacity 320ms var(--ease),transform 320ms var(--ease);will-change:opacity,transform;}
.ftp.ftp-motion .fx.on{opacity:1;transform:none;}

/* ---- 00 opening ---- */
.ftp .opening{min-height:86vh;min-height:86svh;display:grid;grid-template-columns:170px minmax(0,1fr) 240px;gap:36px;align-items:end;padding:calc(56px + 7vh) 2.5vw 5vh;}
.ftp .open-rail{align-self:start;position:sticky;top:96px;}
.ftp .open-title{font-family:'Fraunces',serif;font-weight:900;font-variation-settings:'opsz' 144;font-size:clamp(40px,3.6vw,56px);line-height:.95;letter-spacing:-.02em;margin-bottom:34px;}
.ftp .open-meta{display:flex;flex-direction:column;gap:16px;}
.ftp .open-meta dt{font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gray2);margin-bottom:2px;}
.ftp .open-meta dd{font-size:12.5px;line-height:1.55;margin:0;}
.ftp .open-media{align-self:center;}
.ftp .open-text{padding-bottom:2vh;}
.ftp .open-lead{font-family:'Fraunces',serif;font-weight:600;font-size:19px;line-height:1.4;letter-spacing:-.005em;margin-bottom:18px;}
.ftp .open-body{font-size:13px;line-height:1.7;color:#3a3a3a;}

/* ---- chapter scaffolding (01/02/05) ---- */
.ftp .act-01,.ftp .act-02,.ftp .act-05{display:grid;grid-template-columns:200px minmax(0,1fr);gap:40px;padding:0 4vw;}
.ftp .ch-rail{align-self:stretch;}
.ftp .ch-rail .ch-num{position:sticky;top:110px;}
.ftp .ch-body{min-width:0;}

/* 01 — condition: contained sheet, offset right, text under-left */
.ftp .act-01{padding-top:11vh;padding-bottom:12vh;}
.ftp .act-01 .ch-title{margin-bottom:52px;}
.ftp .sheet-right{width:min(64vw,1010px);margin-left:auto;margin-right:1vw;}
.ftp .ch-text-left{margin-top:34px;}

/* 02 — porous ground: larger, left-set, text ahead of the sheet */
.ftp .act-02{padding-top:6vh;padding-bottom:13vh;}
.ftp .act-02 .ch-title{margin-bottom:16px;}
.ftp .ch-text-offset{margin-bottom:44px;}
.ftp .sheet-wide{width:min(76vw,1310px);margin-left:calc(-200px - 40px + 0vw);}

/* 03 — material cycle: sticky left rail + large technical sheet right */
.ftp .act-03{display:grid;grid-template-columns:280px minmax(0,1fr);gap:48px;align-items:start;padding:6vh 0 13vh 4vw;}
.ftp .side-rail{position:sticky;top:110px;display:flex;flex-direction:column;gap:14px;}
.ftp .ch-title-s{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(19px,1.8vw,24px);line-height:1.2;letter-spacing:-.01em;}
.ftp .ch-text-s{font-size:13px;line-height:1.7;color:#3a3a3a;max-width:280px;}
.ftp .sheet-tech{width:min(72vw,1240px);justify-self:end;margin-right:0;}
.ftp .sheet-tech img{border-right:0;}

/* 04 — seasonal: asymmetric pair, immersive */
.ftp .act-04{padding:9vh 4vw 12vh;}
.ftp .ch-head{display:flex;flex-direction:column;gap:10px;margin-bottom:6vh;}
.ftp .season-pair{display:grid;grid-template-columns:minmax(0,4fr) minmax(0,5fr);gap:min(4vw,56px);align-items:start;width:min(84vw,1400px);}
.ftp .season-a{width:min(30vw,500px);justify-self:end;}
.ftp .season-b{margin-top:16vh;}
.ftp .season-pair figcaption{margin-top:10px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--gray2);}
.ftp .season-text{margin:7vh 0 0 auto;margin-right:6vw;}

/* 05 — living with water + edge peek */
.ftp .act-05{padding-top:9vh;padding-bottom:0;}
.ftp .act-05 .ch-title{margin-bottom:48px;}
.ftp .sheet-live{width:min(72vw,1200px);}
.ftp .peek-wrap{grid-column:1 / -1;margin-top:13vh;display:flex;justify-content:flex-end;}
.ftp .peek{width:min(58vw,900px);margin-right:calc(-4vw - 5vw);}

/* 06 — closing */
.ftp .closing{padding:16vh 4vw 14vh;}
.ftp .close-inner{max-width:1400px;margin:0 auto;padding-top:40px;border-top:1px solid var(--hair);display:flex;flex-direction:column;gap:14px;align-items:flex-start;}
.ftp .next-link{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(26px,3vw,40px);letter-spacing:-.01em;text-decoration:none;border-bottom:1.5px solid var(--ink);padding-bottom:3px;}
.ftp .next-link:hover{opacity:.6;}
.ftp .back-link{margin-top:22px;font-size:12px;letter-spacing:.06em;color:var(--gray2);text-decoration:none;}
.ftp .back-link:hover{color:var(--ink);}
.ftp a:focus-visible{outline:2px solid var(--ink);outline-offset:3px;}

/* ---- tablet 768–1024 ---- */
@media (max-width:1024px){
  .ftp .opening{grid-template-columns:1fr;gap:0;align-items:start;min-height:auto;padding:calc(56px + 5vh) 5vw 8vh;}
  .ftp .open-rail{position:static;order:1;margin-bottom:40px;}
  .ftp .open-title{font-size:clamp(44px,7vw,64px);}
  .ftp .open-meta{flex-direction:row;flex-wrap:wrap;gap:22px 44px;max-width:640px;}
  .ftp .open-media{order:2;width:100%;}
  .ftp .open-text{order:3;margin-top:36px;max-width:520px;padding-bottom:0;}
  .ftp .act-01,.ftp .act-02,.ftp .act-05{grid-template-columns:1fr;gap:0;padding-left:5vw;padding-right:5vw;}
  .ftp .ch-rail .ch-num{position:static;margin-bottom:12px;}
  .ftp .sheet-right{width:min(90vw,1010px);margin:0;}
  .ftp .sheet-wide{width:90vw;margin-left:0;}
  .ftp .act-03{grid-template-columns:1fr;gap:32px;padding:5vh 5vw 10vh;}
  .ftp .side-rail{position:static;max-width:560px;}
  .ftp .ch-text-s{max-width:480px;}
  .ftp .sheet-tech{width:90vw;justify-self:start;}
  .ftp .sheet-tech img{border-right:1px solid rgba(0,0,0,.05);}
  .ftp .season-pair{width:100%;}
  .ftp .season-a{width:100%;}
  .ftp .season-b{margin-top:10vh;}
  .ftp .season-text{margin:6vh 0 0;}
  .ftp .sheet-live{width:90vw;}
  .ftp .peek{width:74vw;margin-right:-9vw;}
}

/* ---- mobile ---- */
@media (max-width:640px){
  .ftp .opening{padding:calc(56px + 3vh) 5vw 6vh;}
  .ftp .open-title{font-size:clamp(42px,13vw,58px);margin-bottom:26px;}
  .ftp .open-meta{flex-direction:column;gap:14px;}
  .ftp .open-lead{font-size:17px;}
  .ftp .act-01,.ftp .act-02,.ftp .act-04,.ftp .act-05{padding-top:8vh;padding-bottom:9vh;}
  .ftp .act-01 .ch-title,.ftp .act-05 .ch-title{margin-bottom:30px;}
  .ftp .sheet-right,.ftp .sheet-wide,.ftp .sheet-live,.ftp .sheet-tech{width:100%;}
  .ftp .ch-text{max-width:none;}
  .ftp .ch-text-left{margin-top:22px;}
  .ftp .ch-text-offset{margin-bottom:26px;}
  .ftp .act-03{padding-bottom:9vh;}
  .ftp .ch-head{margin-bottom:4vh;}
  .ftp .season-pair{grid-template-columns:1fr;gap:36px;}
  .ftp .season-a{justify-self:start;}
  .ftp .season-b{margin-top:0;}
  .ftp .season-text{margin-top:4vh;margin-right:0;}
  .ftp .peek-wrap{margin-top:8vh;}
  .ftp .peek{width:88vw;margin-right:-10vw;}
  .ftp .closing{padding:11vh 5vw 12vh;}
}

@media (prefers-reduced-motion:reduce){
  .ftp .fx{opacity:1!important;transform:none!important;}
}
</style>

<script>
  const root = document.getElementById('ftp');
  if (root && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    root.classList.add('ftp-motion');
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('on');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
    );
    root.querySelectorAll('.fx').forEach((el) => io.observe(el));
  }
</script>

</BaseLayout>
