---
/*
 * LOCAL CMS PILOT — Phase 2A per-project comparison. Unlinked, noindex.
 * Column A renders from the local registry (current production source);
 * column B renders from the Sanity document THROUGH the frontend adapter,
 * so the adapter output itself is what is visually verified.
 */
import { PROJECTS, sheetPath, sheetDims } from '../../../data/projects';
import { sanityClient, sanityConfigured } from '../../../lib/sanity/client';
import { PROJECT_BY_SLUG, HOMEPAGE_SETTINGS } from '../../../lib/sanity/queries';
import type { SanityProject, SanityHomepageSettings } from '../../../lib/sanity/types';
import { buildProjectChecks, findPlacement } from '../../../lib/sanity/compare';
import { toProject } from '../../../lib/sanity/adapter';

export function getStaticPaths() {
  /* Development-only comparison tooling: emit no pages in production builds. */
  if (import.meta.env.PROD) return [];
  return PROJECTS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const local = PROJECTS.find((p) => p.slug === slug);
if (!local) throw new Error(`Unknown project slug: ${slug}`);

let cms: SanityProject | null = null;
let settings: SanityHomepageSettings | null = null;
let cmsError: string | null = null;
if (!sanityConfigured) {
  cmsError = 'Sanity is not configured — set SANITY_PROJECT_ID in .env and rebuild.';
} else {
  try {
    [cms, settings] = await Promise.all([
      sanityClient.fetch<SanityProject | null>(PROJECT_BY_SLUG, { slug }),
      sanityClient.fetch<SanityHomepageSettings | null>(HOMEPAGE_SETTINGS),
    ]);
    if (!cms) cmsError = `No published project with slug "${slug}" in Sanity.`;
  } catch (e) {
    cmsError = `Sanity query failed: ${e instanceof Error ? e.message : String(e)}`;
  }
}

const placement = cms ? findPlacement(settings, local.slug) : null;
const checks = cms ? buildProjectChecks(local, cms, placement) : [];
const allPass = checks.length > 0 && checks.every((c) => c.pass);
const adapted = cms ? toProject(cms, local.tier) : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<meta content="noindex, nofollow" name="robots" />
<title>CMS Pilot — {local.title} comparison</title>
</head>
<body>
<div class="wrap">
  <p class="banner">Local CMS pilot — Phase 2A comparison. Not part of the public site.</p>
  <p><a href="/cms-preview/projects">&larr; All projects</a></p>
  <h1>{local.title} — Local registry vs Sanity (via adapter)</h1>

  <section class="report">
    <h2>Automated comparison {cms ? (allPass ? '— ALL PASS' : '— MISMATCHES FOUND') : ''}</h2>
    {cmsError && <p class="err">{cmsError}</p>}
    {cms && (
      <table>
        <thead><tr><th>Check</th><th>Result</th><th>Detail</th></tr></thead>
        <tbody>
          {checks.map((c) => (
            <tr class={c.pass ? 'pass' : 'fail'}>
              <td>{c.label}</td>
              <td>{c.pass ? 'PASS' : 'FAIL'}</td>
              <td class="detail">{c.detail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </section>

  <div class="cols">
    <section class="col">
      <h2>A — Local registry (production source)</h2>
      <h3>{local.title}</h3>
      <p class="meta-line">{local.cardMeta}</p>
      <dl>
        {local.meta.map((m) => (
          <div><dt>{m.k}</dt><dd>{m.v}</dd></div>
        ))}
      </dl>
      <p class="desc">{local.desc}</p>
      {local.sheets.map((s, i) => {
        const d = sheetDims(s);
        return (
          <figure>
            <img src={sheetPath(local, s)} width={d.width} height={d.height}
              alt={`${local.title} — sheet ${i + 1} of ${local.sheets.length}`}
              loading="lazy" decoding="async" />
            <figcaption>{typeof s === 'string' ? s : s.file}</figcaption>
          </figure>
        );
      })}
    </section>

    <section class="col">
      <h2>B — Sanity via frontend adapter (published)</h2>
      {cmsError && <p class="err">{cmsError}</p>}
      {adapted && (
        <>
          <h3>{adapted.title}</h3>
          <p class="meta-line">{adapted.cardMeta}</p>
          <dl>
            {adapted.meta.map((m) => (
              <div><dt>{m.k}</dt><dd>{m.v}</dd></div>
            ))}
          </dl>
          <p class="desc">{adapted.desc}</p>
          {adapted.sheets.map((s, i) => {
            const d = sheetDims(s);
            return (
              <figure>
                <img src={sheetPath(adapted, s)} width={d.width} height={d.height}
                  alt={(cms!.gallery ?? [])[i]?.alt ?? `${adapted.title} — sheet ${i + 1}`}
                  loading="lazy" decoding="async" />
                <figcaption>{(cms!.gallery ?? [])[i]?.image.asset.originalFilename}</figcaption>
              </figure>
            );
          })}
        </>
      )}
    </section>
  </div>
</div>

<style>
  * { box-sizing: border-box; }
  body { margin: 0; font: 14px/1.6 system-ui, sans-serif; color: #111; background: #fafaf8; }
  .wrap { max-width: 1500px; margin: 0 auto; padding: 24px 3vw 80px; }
  .banner { background: #111; color: #fff; padding: 8px 14px; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; display: inline-block; }
  h1 { font-size: 22px; margin: 12px 0 26px; }
  h2 { font-size: 15px; margin: 0 0 14px; letter-spacing: 0.04em; text-transform: uppercase; }
  h3 { font-size: 19px; margin: 0 0 4px; }
  .report { margin-bottom: 36px; }
  table { border-collapse: collapse; width: 100%; max-width: 980px; font-size: 13px; }
  th, td { text-align: left; padding: 6px 12px; border-bottom: 1px solid #ddd; vertical-align: top; }
  tr.pass td:nth-child(2) { color: #1a7f37; font-weight: 600; }
  tr.fail td:nth-child(2) { color: #b42318; font-weight: 700; }
  .detail { overflow-wrap: anywhere; }
  .err { color: #b42318; font-weight: 600; max-width: 640px; }
  .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 3vw; align-items: start; }
  .col { min-width: 0; }
  .meta-line { color: #666; margin: 0 0 14px; }
  dl { margin: 0 0 16px; }
  dl div { margin-bottom: 6px; }
  dt { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: #888; }
  dd { margin: 0; white-space: pre-line; }
  .desc { max-width: 560px; margin: 0 0 22px; }
  figure { margin: 0 0 20px; }
  img { display: block; width: 100%; height: auto; border: 1px solid #e2e2de; }
  figcaption { font-size: 11px; color: #888; margin-top: 5px; }
  @media (max-width: 900px) { .cols { grid-template-columns: 1fr; } }
</style>
</body>
</html>
