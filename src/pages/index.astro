---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import LegacyWorkGrid from '../components/LegacyWorkGrid.astro';
import ObservationsPreview from '../components/ObservationsPreview.astro';
import Footer from '../components/Footer.astro';
import ProjectRooms from '../components/ProjectRooms.astro';
import { getSiteSettings } from '../lib/sanity/content';

const settings = await getSiteSettings();
---
<BaseLayout title={settings.seoDefaultTitle}>
<Header />
<Hero />
<LegacyWorkGrid />
<ObservationsPreview />
<Footer />
<ProjectRooms />
</BaseLayout>
