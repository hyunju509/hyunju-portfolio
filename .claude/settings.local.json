{
  "permissions": {
    "allow": [
      "PowerShell(node -v)",
      "PowerShell(npm -v)",
      "PowerShell(Get-Command winget -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command choco -ErrorAction SilentlyContinue)",
      "PowerShell(winget --version 2>$null)",
      "PowerShell(winget install OpenJS.NodeJS.LTS --accept-source-agreements --accept-package-agreements)",
      "Bash(npm -v)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git config *)",
      "Bash(mkdir -p src/layouts src/components src/pages src/styles src/data public/documents public/js)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(rmdir js *)",
      "Bash(powershell -Command \"Get-CimInstance Win32_Process -Filter \\\\\"name='node.exe'\\\\\" | Select-Object ProcessId,CommandLine\")",
      "Bash(powershell -Command 'Stop-Process -Id 1988,19068,45172,13944 -Force -Confirm:$false')"
    ]
  }
}
